ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-5-20250929

# CSV: include Buy price (or Price / Avg buy) per row for accurate P&L. Purchase date helps when price is blank.
# STRICT_COST_BASIS=1   — fail if any row lacks a positive buy price
# SKIP_CLAUDE_COST_BASIS=1 — do not use Claude to guess historical cost basis

# Optional: full path to portfolio CSV for `python src/main.py` default (Enter key)
# PORTFOLIO_CSV=C:\Users\You\Downloads\Nexus_AI_Portfolio_Tracker(Portfolio).csv

FINNHUB_API_KEY=
NEWSDATA_API_KEY=YOUR_NEWSDATA_API_KEY
# Optional: live market quote source (google_finance via SerpAPI)
# SERPAPI_API_KEY=

# API_PORT=8010  (default). Must match Vite proxy — same file is loaded by frontend/vite.config.js.
# If /api/* returns 404 {detail:"Not Found"}, another app may be using the port; change API_PORT here and restart python + npm run dev.
# Browser: http://127.0.0.1:${API_PORT}/docs — not http://0.0.0.0

# Frontend (Vite loads nexus_agent/.env). For Netlify/production builds, set your Render API URL:
# VITE_API_BASE_URL=https://your-service.onrender.com
# Leave unset for local dev (uses /api proxy to localhost).
